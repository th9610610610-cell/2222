{
  "version": 2,
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/lotto-win run build",
  "outputDirectory": "artifacts/lotto-win/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
