{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "../.vercel/output/functions",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../artifacts/api-server/src/**/*.ts",
    "../lib/db/src/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
